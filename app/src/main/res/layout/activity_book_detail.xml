<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E0E0">

    <ScrollView
        android:id="@+id/detailScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/detailBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="96dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_top_bar_light"
                android:gravity="center"
                android:text="Название книги"
                android:textColor="#1F4E79"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/detailCover"
                android:layout_width="140dp"
                android:layout_height="190dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_genre_tile_light"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_books" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/detailType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Тип:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailGenre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Жанр:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Тема:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Автор:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailYear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Выпуск:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detailHeroes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Главные герои:"
                    android:textColor="#111111"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Статус"
                        android:textColor="#111111"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/detailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/detailBottomBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_light"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/detailNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_home_a11y"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="@string/nav_home"
            android:textColor="#1F4E79"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#1F4E79" />

        <TextView
            android:id="@+id/detailNavMyBooks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_my_books_a11y"
            app:drawableTopCompat="@drawable/ic_library"
            android:drawablePadding="4dp"
            android:text="@string/nav_my_books"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />

        <TextView
            android:id="@+id/detailNavProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_profile_a11y"
            app:drawableTopCompat="@drawable/ic_profile_standart"
            android:drawablePadding="4dp"
            android:text="@string/nav_profile"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
