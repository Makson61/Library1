<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/genreRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E0E0">

    <TextView
        android:id="@+id/genreTitle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_top_bar_light"
        android:gravity="center"
        android:text="Название жанра"
        android:textColor="#1F4E79"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/genreRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="88dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/genreTitle"
        app:layout_constraintBottom_toTopOf="@id/genreBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:itemCount="6"
        tools:listitem="@layout/item_book_row" />

    <LinearLayout
        android:id="@+id/genreBottomBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_light"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/genreNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_home_a11y"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="@string/nav_home"
            android:textColor="#1F4E79"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#1F4E79" />

        <TextView
            android:id="@+id/genreNavMyBooks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_my_books_a11y"
            app:drawableTopCompat="@drawable/ic_library"
            android:drawablePadding="4dp"
            android:text="@string/nav_my_books"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />

        <TextView
            android:id="@+id/genreNavProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_profile_a11y"
            app:drawableTopCompat="@drawable/ic_profile_standart"
            android:drawablePadding="4dp"
            android:text="@string/nav_profile"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
