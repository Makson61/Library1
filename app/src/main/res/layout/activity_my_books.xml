<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/myBooksRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0E0E0">

    <TextView
        android:id="@+id/myBooksTitle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_top_bar_light"
        android:gravity="center"
        android:text="@string/my_books_title"
        android:textColor="#1F4E79"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/myBooksSearchRow"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/myBooksTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/myBooksSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_search_light"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/myBooksClear"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_white"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:tint="#000000" />

        <ImageView
            android:id="@+id/myBooksFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_white"
            android:padding="6dp"
            android:src="@drawable/ic_menu"
            android:tint="#1F4E79" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/myBooksRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="88dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/myBooksSearchRow"
        app:layout_constraintBottom_toTopOf="@id/myBooksBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/myBooksBottomBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_light"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/myBooksNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_home_a11y"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="@string/nav_home"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />

        <TextView
            android:id="@+id/myBooksNavMyBooks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_my_books_a11y"
            app:drawableTopCompat="@drawable/ic_library"
            android:drawablePadding="4dp"
            android:text="@string/nav_my_books"
            android:textColor="#1F4E79"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="false"
            android:focusable="false"
            app:drawableTint="#1F4E79" />

        <TextView
            android:id="@+id/myBooksNavProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_profile_a11y"
            app:drawableTopCompat="@drawable/ic_profile"
            android:drawablePadding="4dp"
            android:text="@string/nav_profile"
            android:textColor="#222222"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#222222" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
