<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/myBooksRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1F1F">

    <TextView
        android:id="@+id/myBooksTitle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_top_bar_dark"
        android:gravity="center"
        android:text="@string/my_books_title"
        android:textColor="#8B56FF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/myBooksSearchRow"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/myBooksTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/myBooksSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_search_dark"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="#6B6B6B"
            android:hint="@string/search_my_books_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="#111111"
            android:textColorHint="#666666"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/myBooksClear"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/cd_clear"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:tint="#000000" />

        <ImageView
            android:id="@+id/myBooksFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="6dp"
            android:src="@drawable/ic_menu"
            android:contentDescription="@string/cd_filter"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:tint="#8B56FF" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/myBooksFiltersScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/myBooksSearchRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/myBooksFiltersRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/myBooksFilterStatus"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingHorizontal="12dp"
                android:text="@string/filter_status"
                android:textColor="@color/filter_chip_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/myBooksFilterGenre"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingHorizontal="12dp"
                android:text="@string/filter_genre"
                android:textColor="@color/filter_chip_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/myBooksFilterYear"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingHorizontal="12dp"
                android:text="@string/filter_year"
                android:textColor="@color/filter_chip_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/myBooksFilterReset"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_filter_chip"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingHorizontal="12dp"
                android:text="@string/filters_reset"
                android:textColor="@color/filter_chip_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/myBooksResultsInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/results_count"
        android:textColor="#B0B0B0"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/myBooksFiltersScroll"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/myBooksRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="88dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/myBooksResultsInfo"
        app:layout_constraintBottom_toTopOf="@id/myBooksBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/myBooksEmptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/myBooksResultsInfo"
        app:layout_constraintBottom_toTopOf="@id/myBooksBottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_results_title"
            android:textColor="#8B56FF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/empty_results_hint"
            android:textColor="#B0B0B0"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/myBooksBottomBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_dark"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/myBooksNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_home_a11y"
            app:drawableTopCompat="@drawable/ic_home"
            android:drawablePadding="4dp"
            android:text="@string/nav_home"
            android:textColor="#BFBFBF"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#BFBFBF" />

        <TextView
            android:id="@+id/myBooksNavMyBooks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_my_books_a11y"
            app:drawableTopCompat="@drawable/ic_library"
            android:drawablePadding="4dp"
            android:text="@string/nav_my_books"
            android:textColor="#8B56FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:clickable="false"
            android:focusable="false"
            app:drawableTint="#8B56FF" />

        <TextView
            android:id="@+id/myBooksNavProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:contentDescription="@string/nav_profile_a11y"
            app:drawableTopCompat="@drawable/ic_profile_standart"
            android:drawablePadding="4dp"
            android:text="@string/nav_profile"
            android:textColor="#BFBFBF"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true"
            app:drawableTint="#BFBFBF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
